{
  "extends": "@tally/config/tsconfig/node",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "customConditions": ["development"],
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "src/**/*.test.ts"]
}
